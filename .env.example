# ======================================================
# 終活・相続情報センター 環境変数テンプレート
# Vercel Dashboard → Settings → Environment Variables に設定
# ======================================================

# Google Analytics 4（GA4）測定ID
# 取得: https://analytics.google.com → 管理 → データストリーム → 測定ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense パブリッシャーID（承認後に設定）
# 取得: https://adsense.google.com → アカウント → パブリッシャーID
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXX

# サイトURL（本番環境）
# Vercel デプロイURL または カスタムドメイン
NEXT_PUBLIC_SITE_URL=https://lastletter-seo-site.vercel.app

# OpenAI API キー（GitHub Actions での記事自動生成用）
# 取得: https://platform.openai.com/api-keys
# ※ GitHub Repository Secrets に設定（Actions → Secrets and variables → Actions）
OPENAI_API_KEY=sk-proj-...
